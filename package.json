{
  "name": "gemini-ats",
  "version": "1.0.0",
  "description": "ATS resume generator with BYOK Gemini",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "electron-store": "^10.0.1",
    "keytar": "^7.9.0",
    "puppeteer": "^24.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1"
  }
}
